# Environment variables — Prospecta
# Copy to .env and fill locally. Never commit real secrets.

# PostgreSQL connection string
DATABASE_URL="postgresql://prospecta:prospecta@localhost:5433/prospecta"

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth — long random string (min 32 chars). Roles V1: ADMIN | MEMBER
AUTH_SECRET="replace-with-long-random-string-at-least-32-chars"

# Seed passwords (fictitious users only — never production secrets)
SEED_ADMIN_PASSWORD="replace-admin-seed-password"
SEED_MEMBER_PASSWORD="replace-member-seed-password"

# Machine-to-machine lead ingestion (Lead Intelligence / generator)
PROSPECTA_IMPORT_TOKEN="replace-with-long-random-import-token"
# Fallback owner when payload omits ownerEmail
LEAD_INGEST_DEFAULT_OWNER_EMAIL="comercial@prospecta.test"

# Optional Playwright overrides (defaults match seed emails)
# E2E_ADMIN_EMAIL="admin@prospecta.test"
# E2E_ADMIN_PASSWORD=
# E2E_MEMBER_EMAIL="comercial@prospecta.test"
# E2E_MEMBER_PASSWORD=
