# Environment variables — Prospecta
# Copy to .env and fill locally. Never commit real secrets.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/prospecta?sslmode=require"

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (placeholder — implement in auth vertical slice)
# Roles in V1: ADMIN | MEMBER (PARTNER is societal, not an ACL claim)
# AUTH_SECRET="replace-with-long-random-string"
# BOOTSTRAP_ADMIN_EMAIL="you@example.com"
# BOOTSTRAP_ADMIN_PASSWORD="replace-me"

# MCP (prefer shell export / local .cursor/mcp.json — never commit tokens)
# CONTEXT7_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=
