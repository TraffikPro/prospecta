// Prospecta V1 — initial schema (no UI yet)
// Product decisions: docs/product/product-decision-mvp-technical.md
// ADR: docs/adr/0002-pipeline-lead-activity-v1.md, docs/adr/0003-auth-roles-v1.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum LeadStage {
  NEW
  QUALIFIED
  CONTACTED
  MEETING
  WON
  LOST
}

enum ActivityType {
  WHATSAPP
  EMAIL
  NOTE
  STAGE_CHANGE
}

enum ActivityOutcome {
  SENT_NO_REPLY
  REPLIED
  NOT_INTERESTED
  INTERESTED
  MEETING_SCHEDULED
  WRONG_CONTACT
  OTHER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(MEMBER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ownedLeads   Lead[]     @relation("LeadOwner")
  activities   Activity[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id             String     @id @default(cuid())
  companyName    String
  contactName    String?
  title          String?
  email          String?
  phone          String?
  website        String?
  notes          String?
  stage          LeadStage  @default(NEW)
  nextFollowUpAt DateTime?
  lostReason     String?
  wonNote        String?
  ownerId        String
  owner          User       @relation("LeadOwner", fields: [ownerId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  activities     Activity[]

  @@index([stage])
  @@index([ownerId])
  @@index([nextFollowUpAt])
  @@index([email])
  @@index([phone])
}

model Activity {
  id              String           @id @default(cuid())
  leadId          String
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  type            ActivityType
  outcome         ActivityOutcome?
  body            String?
  templateSnapshot String?
  createdAt       DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([authorId])
}
